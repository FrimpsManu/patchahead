# All optional. The deterministic demo runs with none of these set.

# Use Claude for changelog reasoning + patch generation (deterministic fallback otherwise).
PATCHAHEAD_USE_LLM=0
ANTHROPIC_API_KEY=

# Send agent-workflow spans to Sentry (console-trace fallback otherwise).
SENTRY_DSN=

# Store / retrieve similar past migrations (no-op fallback otherwise).
REDIS_URL=
